# Frontend Environment Variables Example
# Copy this file to .env and fill in your actual values

# Backend API URL (use your deployed backend URL in production)
REACT_APP_API_URL=http://localhost:8000
# Production example: REACT_APP_API_URL=https://your-backend.onrender.com

# WebSocket URL (usually same as API URL)
REACT_APP_SOCKET_URL=http://localhost:8000

# OpenRouter API Key (for AI features in the frontend)
# Get your free API key at https://openrouter.ai/keys
REACT_APP_OPENROUTER_API_KEY=your_openrouter_api_key_here
